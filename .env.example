# Copy to .env and fill any key to flip that sponsor from MOCK -> LIVE.
# The demo runs fully without any of these.

# Reasoning (Kimi K2 — verified: OpenAI SDK, base_url below, model kimi-k2.6)
MOONSHOT_API_KEY=
KIMI_MODEL=kimi-k2.6

# Failover / routing gateway (TokenRouter — managed REST, key tr_...)
TOKENROUTER_API_KEY=
TOKENROUTER_BASE_URL=https://api.tokenrouter.io/v1
TOKENROUTER_MODEL=auto:balance

# Perception
BRIGHTDATA_API_TOKEN=
BRIGHTDATA_SERP_ZONE=sdk_serp   # name of an EXISTING SERP zone in your Bright Data account
VIDEO_DB_API_KEY=

# Secure compute
DAYTONA_API_KEY=

# Decentralised GPU (pre-run only)
NOSANA_API_KEY=

# Agent identity / verifiable mandate (Terminal 3 — terminal3.io, NOT .com)
TERMINAL3_AGENT_KEY=

# Authorized-action destination for the climax
VERDICT_GIT_COMMIT=        # set to 1 to git-commit the signed memo
SLACK_WEBHOOK_URL=

# --- Terminal 3 sidecar (run `node notary_sidecar/server.js` → auto-detected) ---
TERMINAL3_SIDECAR_URL=http://127.0.0.1:8787

# --- Pre-indexed VideoDB earnings videos (id from a one-time pre-stage) ---
VIDEODB_ID_SEA=
VIDEODB_ID_GRAB=
VIDEODB_ID_GOTO=

# --- Nosana pre-run job (receipt only) ---
NOSANA_JOB_ID=
